rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the auth session document for the current user
    function getSession() {
      return get(/databases/$(database)/documents/authSessions/$(request.auth.uid)).data;
    }

    // Get the role from the auth session
    function getUserRole() {
      return getSession().role;
    }

    // Get the companyId from the auth session
    function getUserCompanyId() {
      return getSession().companyId;
    }

    // Get the userId from the auth session
    function getUserId() {
      return getSession().userId;
    }

    // Role checks
    function isSuperAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/authSessions/$(request.auth.uid)) &&
             getUserRole() == 'super_admin';
    }

    function isCompanyAdmin() {
      return isAuthenticated() && getUserRole() == 'company_admin';
    }

    function isHR() {
      return isAuthenticated() && getUserRole() == 'hr';
    }

    function isAdminOrHR() {
      return isAuthenticated() && getUserRole() in ['super_admin', 'company_admin', 'hr'];
    }

    function isCompanyStaff() {
      return isAuthenticated() && getUserRole() in ['super_admin', 'company_admin', 'hr', 'employee'];
    }

    // Company membership check
    function belongsToCompany(companyId) {
      return isAuthenticated() && getUserCompanyId() == companyId;
    }

    // Check if user is super_admin OR belongs to the given company
    function isSuperAdminOrBelongsToCompany(companyId) {
      return isSuperAdmin() || belongsToCompany(companyId);
    }

    // Check if the user is in the login flow (temporary pending session).
    // During login, a temporary authSession with role "pending" is created
    // before the user queries run. This allows the login queries to proceed.
    function isLoginPending() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/authSessions/$(request.auth.uid))
        && getSession().role == 'pending';
    }

    // Check if user is admin/HR in the given company
    function isAdminOrHRInCompany(companyId) {
      return isAdminOrHR() && (isSuperAdmin() || getUserCompanyId() == companyId);
    }

    // ============================================
    // AUTH SESSIONS COLLECTION
    // ============================================
    // Stores the mapping between Firebase Auth UID and custom user data.
    // Each user can only read/write their own session.
    match /authSessions/{sessionId} {
      allow read: if isAuthenticated() && request.auth.uid == sessionId;
      allow create: if isAuthenticated() && request.auth.uid == sessionId;
      allow update: if isAuthenticated() && request.auth.uid == sessionId;
      allow delete: if isAuthenticated() && request.auth.uid == sessionId;
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
    // - Users can read their own profile
    // - Admin/HR can read users in their company
    // - Super admins can read all users
    // - Only admin/HR/super_admin can create/update users
    // - Users can update their own non-role fields
    match /users/{userId} {
  allow read: if isAuthenticated()
    && (isSuperAdmin()
        || getUserId() == userId
        || getUserCompanyId() == resource.data.companyId
        || isLoginPending()
        || request.auth.token.firebase.sign_in_provider == 'anonymous');

  allow create: if isAdminOrHR()
    || isSuperAdmin()
    || request.auth.token.firebase.sign_in_provider == 'anonymous';

  allow update: if isAuthenticated()
    && (isSuperAdmin()
        || (isAdminOrHR() && getUserCompanyId() == resource.data.companyId)
        || (getUserId() == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'companyId'])));

  allow delete: if isSuperAdmin();
}

    // ============================================
    // COMPANIES COLLECTION
    // ============================================
    // - Users can read their own company
    // - Super admins can read/write all companies
    // - Company admins can update their own company (non-critical fields)
    match /companies/{companyId} {
  // Allow unauthenticated reads for QR registration flow
  allow read: if true;

  // Keep all writes locked down
  allow create: if isSuperAdmin();
  allow update: if isSuperAdmin()
    || (isCompanyAdmin() && belongsToCompany(companyId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isActive']));
  allow delete: if isSuperAdmin();
}

    // ============================================
    // POSTS COLLECTION
    // ============================================
    // - Users in the same company can read posts (company-level isolation)
    // - Privacy filtering (department_only, hr_only) is enforced client-side
    //   in getPostsWithPrivacyFilter() to avoid Firestore query validation
    //   failures with complex OR rules and get() calls
    // - Authenticated users can create posts for their company
    // - Post authors, admin/HR can update posts
    // - Post authors, admin/HR can delete posts; super_admin can delete any
    match /posts/{postId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
            || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserId() == resource.data.authorId
                    || request.auth.uid == resource.data.authorId
                    || getUserRole() in ['hr', 'company_admin']
                    || ('assignedTo' in resource.data && resource.data.assignedTo != null
                        && getUserId() == resource.data.assignedTo.id))));

      allow delete: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserId() == resource.data.authorId
                    || request.auth.uid == resource.data.authorId
                    || getUserRole() in ['hr', 'company_admin'])));

      // Likes subcollection
      match /likes/{likeId} {
        allow read: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        allow create: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        // Allow like owner to unlike, or post author/admin to delete during post deletion
        allow delete: if isAuthenticated()
          && (isSuperAdmin()
              || getUserId() == likeId
              || request.auth.uid == likeId
              || (getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId
                  && (getUserId() == get(/databases/$(database)/documents/posts/$(postId)).data.authorId
                      || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorId
                      || getUserRole() in ['hr', 'company_admin'])));
        allow update: if false;
      }

      // Comments subcollection (used by deletePost cascade)
      match /comments/{commentId} {
        allow read: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        allow create: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        // Allow comment author, post author, or admin/HR to delete
        allow delete: if isAuthenticated()
          && (isSuperAdmin()
              || (getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId
                  && (getUserId() == resource.data.authorId
                      || request.auth.uid == resource.data.authorId
                      || getUserId() == get(/databases/$(database)/documents/posts/$(postId)).data.authorId
                      || request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorId
                      || getUserRole() in ['hr', 'company_admin'])));
        allow update: if false;
      }

      // Reactions subcollection (used by deletePost cascade)
      match /reactions/{reactionId} {
        allow read: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        allow create: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        allow delete: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/posts/$(postId)).data.companyId);
        allow update: if false;
      }
    }

    // ============================================
    // COMMENTS COLLECTION
    // ============================================
    // - Users in the same company as the post can read/create comments
    // - Comment authors can update their own comments
    // - Admin/HR can update/delete any comment in their company
    match /comments/{commentId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
            || getUserCompanyId() == resource.data.companyId
            || (resource.data.isAdminComment == true && !('companyId' in resource.data)));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserId() == resource.data.authorId
                    || getUserRole() in ['hr', 'company_admin'])));

      allow delete: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserId() == resource.data.authorId
                    || getUserRole() in ['hr', 'company_admin'])));
    }

    // ============================================
    // DISCUSSIONS COLLECTION
    // ============================================
    // - Users in the same company can read/create discussions
    // - Authors and admin/HR can update discussions
    match /discussions/{discussionId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserId() == resource.data.authorId
                    || getUserRole() in ['hr', 'company_admin'])));

      allow delete: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserRole() in ['hr', 'company_admin']
                && getUserCompanyId() == resource.data.companyId));
    }

    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    // - Users can only read/update their own notifications
    // - System (admin/HR) can create notifications for users in their company
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == resource.data.userId);

      allow create: if isAuthenticated()
        && (isSuperAdmin()
            || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == resource.data.userId);

      allow delete: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == resource.data.userId);
    }

    // ============================================
    // POST ACTIVITIES COLLECTION (Timeline)
    // ============================================
    // - Users in the same company can read activities
    // - Authenticated users can create activities for their company's posts
    match /postActivities/{activityId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserRole() in ['hr', 'company_admin']
                && getUserCompanyId() == resource.data.companyId));

      // Allow deletion during post soft-delete cascade
      allow delete: if isAuthenticated()
        && (isSuperAdmin()
            || getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // POST VIEWS COLLECTION
    // ============================================
    // - Users can read/create views for posts in their company
    match /postViews/{viewId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserId() == resource.data.userId
                && getUserCompanyId() == resource.data.companyId));

      // Allow deletion during post soft-delete cascade
      allow delete: if isAuthenticated()
        && (isSuperAdmin()
            || getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // DEPARTMENTS COLLECTION
    // ============================================
    // - Users in the same company can read departments
    // - Admin/HR can manage departments
    match /departments/{departmentId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if isSuperAdmin()
        || (isCompanyAdmin() && getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // SYSTEM AUDIT LOGS COLLECTION
    // ============================================
    // - Admin/HR can read audit logs for their company
    // - Super admins can read all
    // - Created by system (admin actions)
    // - Never updated or deleted (immutable)
    match /systemAuditLogs/{logId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // USER TAGS COLLECTION
    // ============================================
    // - Users in the same company can read tags
    // - Admin/HR can manage tags
    match /userTags/{tagId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // CONTENT MODERATION: REPORTS COLLECTION
    // ============================================
    // - Any authenticated user can create a report (for their company)
    // - Users can read their own reports (to check for duplicates)
    // - Admin/HR can read and manage all reports in their company
    match /contentReports/{reportId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
            || (isAdminOrHR() && getUserCompanyId() == resource.data.companyId)
            || getUserId() == resource.data.reportedBy);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // CONTENT MODERATION: USER STRIKES COLLECTION
    // ============================================
    // - Admin/HR can read/manage strikes for users in their company
    match /userStrikes/{strikeId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // CONTENT MODERATION: USER RESTRICTIONS COLLECTION
    // ============================================
    // - Admin/HR can read/manage restrictions
    // - Users can read their own restrictions
    match /userRestrictions/{restrictionId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
            || (isAdminOrHR() && getUserCompanyId() == resource.data.companyId)
            || getUserId() == resource.data.userId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // CONTENT MODERATION: ACTIVITY LOGS COLLECTION
    // ============================================
    // - Admin/HR can read moderation activities
    // - Any authenticated user can create (triggered by reporting content)
    match /moderationActivities/{activityId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // LEGAL REQUESTS COLLECTION
    // ============================================
    // - Company admins and HR can create and read their company's requests
    // - Super admins can read, review, and update all requests
    match /legalRequests/{requestId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isSuperAdmin()
        || (isAdminOrHR() && getUserCompanyId() == resource.data.companyId);

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // SEARCH: SAVED SEARCHES COLLECTION
    // ============================================
    // - Users can manage their own saved searches
    match /savedSearches/{searchId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == resource.data.userId);

      allow create: if isAuthenticated()
        && getUserId() == request.resource.data.userId;

      allow update: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == resource.data.userId);

      allow delete: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == resource.data.userId);
    }

    // ============================================
    // SEARCH: ANALYTICS COLLECTION
    // ============================================
    // - Admin/HR can read search analytics for their company
    // - System can create analytics entries
    match /searchAnalytics/{analyticsId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // NOTIFICATION PREFERENCES COLLECTION
    // ============================================
    // - Users can read/write their own notification preferences
    match /notificationPreferences/{userId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == userId);

      allow write: if isAuthenticated()
        && (isSuperAdmin() || getUserId() == userId);
    }

    // ============================================
    // EMAIL QUEUE COLLECTION
    // ============================================
    // - Only admin/system can manage email queue
    // - Read by Cloud Functions for processing
    match /emailQueue/{emailId} {
      allow read: if isAdminOrHR();
      allow create: if isAuthenticated();
      allow update: if isAdminOrHR();
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // SPLIT-KEY IDENTITY VAULT COLLECTION
    // ============================================
    // Stores Key Part A for each company's anonymous identity encryption.
    // ONLY super_admin may read or write this collection.
    match /keyVault/{companyId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ============================================
    // DISCLOSURE AUDIT LOG COLLECTION
    // ============================================
    // Immutable chain-hashed log of every identity disclosure event.
    // - super_admin may create new entries
    // - Admin/HR can read entries for their company
    // - NO party may update or delete entries
    match /disclosureAuditLog/{logId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);
      allow create: if isSuperAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // ANONYMOUS THREADS COLLECTION
    // ============================================
    // Two-way private messaging between anonymous reporters and investigators.
    // - Admin/HR in the same company can read
    // - Users in the same company can create/update (append messages)
    // - Never deleted
    match /anonymousThreads/{postId} {
      allow read: if isAuthenticated()
        && (resource == null
            || isSuperAdmin()
            || (getUserRole() in ['hr', 'company_admin']
                && getUserCompanyId() == resource.data.companyId)
            || getUserId() == resource.data.reporterId
            || getUserId() == get(/databases/$(database)/documents/posts/$(postId)).data.authorId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserRole() in ['hr', 'company_admin']
                    || getUserId() == resource.data.reporterId
                    || getUserId() == get(/databases/$(database)/documents/posts/$(postId)).data.authorId)));

      allow delete: if false;
    }

    // ============================================
    // POLICIES COLLECTION
    // ============================================
    // - All authenticated users in the same company can read policies
    // - Admin/HR can create and manage policies
    match /policies/{policyId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // VENDOR REPORTS COLLECTION
    // ============================================
    // - Admin/HR can read and manage vendor reports
    // - Never deleted (audit trail)
    match /vendorReports/{reportId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow delete: if false;

      // Corroborations subcollection
      match /corroborations/{corrId} {
        allow read: if isAdminOrHR()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/vendorReports/$(reportId)).data.companyId);

        allow create: if isAdminOrHR()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/vendorReports/$(reportId)).data.companyId);

        allow update: if isAdminOrHR()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/vendorReports/$(reportId)).data.companyId);

        allow delete: if false;
      }
    }

    // ============================================
    // POLICY ACKNOWLEDGEMENTS COLLECTION
    // ============================================
    // - Users can read/create their own acknowledgements
    // - Admin/HR can read all acknowledgements in their company
    // - Allow reads on non-existent docs (resource == null) for existence checks
    match /policyAcknowledgements/{ackId} {
      allow read: if isAuthenticated()
        && (resource == null
            || isSuperAdmin()
            || (isAdminOrHR() && getUserCompanyId() == resource.data.companyId)
            || getUserId() == resource.data.userId);

      allow create: if isAuthenticated()
        && getUserId() == request.resource.data.userId;

      allow update: if false;
      // Allow admin/HR to delete acknowledgements when deleting a policy
      allow delete: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // POST TEMPLATES COLLECTION
    // ============================================
    // - Users in the same company can read templates
    // - Admin/HR can create/manage templates
    // - Template creators can update their own templates
    match /postTemplates/{templateId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == resource.data.companyId
                && (getUserId() == resource.data.createdById
                    || getUserRole() in ['hr', 'company_admin'])));

      allow delete: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);
    }

    // ============================================
    // POST EDIT HISTORY COLLECTION
    // ============================================
    // - Users in the same company can read edit history
    // - Created automatically on post edits
    // - Immutable (no updates or deletes)
    match /postEditHistory/{historyId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;

      // Allow deletion during post soft-delete cascade
      allow delete: if isAuthenticated()
        && (isSuperAdmin()
            || getUserCompanyId() == resource.data.companyId);
    }
    // ============================================
// DEPARTMENT ASSIGNMENT LOGS COLLECTION
// ============================================
// - Admin/HR can read assignment logs for their company
// - Created by system on department assignment actions
// - Immutable (no updates or deletes)
match /departmentAssignmentLogs/{logId} {
  allow read: if isAdminOrHR()
    && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

  allow create: if isAdminOrHR()
    && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

  allow update: if false;
  allow delete: if false;
}

    // ============================================
    // DELETED POSTS COLLECTION (Soft-delete archive)
    // ============================================
    // - Post authors can write when soft-deleting their own posts
    // - Admin/HR/super_admin can read and write
    match /deletedPosts/{postId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin()
            || (getUserCompanyId() == request.resource.data.companyId
                && (getUserId() == request.resource.data.deletedBy.id
                    || request.auth.uid == request.resource.data.deletedBy.id
                    || getUserRole() in ['hr', 'company_admin'])));

      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Subcollections: comments, likes, reactions
      match /{subcollection}/{docId} {
        allow read: if isAdminOrHR()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/deletedPosts/$(postId)).data.companyId);

        allow create: if isAuthenticated()
          && (isSuperAdmin() || getUserCompanyId() == get(/databases/$(database)/documents/deletedPosts/$(postId)).data.companyId
              || getUserCompanyId() == request.resource.data.companyId);

        allow update: if false;
        allow delete: if false;
      }
    }

    // ============================================
    // DELETED POST EDIT HISTORY (Soft-delete archive)
    // ============================================
    match /deletedPostEditHistory/{historyId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // DELETED POST ACTIVITIES (Soft-delete archive)
    // ============================================
    match /deletedPostActivities/{activityId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // DELETED POST VIEWS (Soft-delete archive)
    // ============================================
    match /deletedPostViews/{viewId} {
      allow read: if isAdminOrHR()
        && (isSuperAdmin() || getUserCompanyId() == resource.data.companyId);

      allow create: if isAuthenticated()
        && (isSuperAdmin() || getUserCompanyId() == request.resource.data.companyId);

      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // DENY ALL OTHER COLLECTIONS
    // ============================================
    // Any collection not explicitly listed above is denied by default.
    // Billing and subscription collections (subscriptions, invoices, payments,
    // paymentMethods, usageRecords, billingHistory, pricingTiers,
    // billingDisputes, revenueReports) are intentionally excluded
    // and will be denied by this catch-all rule.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
