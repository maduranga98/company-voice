rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // IMPORTANT: FIREBASE AUTH IS DISABLED
    // ============================================
    // These rules allow unauthenticated access for testing purposes.
    // WARNING: This is NOT suitable for production use.
    // You should implement proper authentication and authorization
    // before deploying to production.
    // ============================================

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read, write: if true;
    }

    // ============================================
    // COMPANIES COLLECTION
    // ============================================
    match /companies/{companyId} {
      allow read, write: if true;
    }

    // ============================================
    // POSTS COLLECTION
    // ============================================
    match /posts/{postId} {
      // Write access: allow all for testing
      allow write: if true;

      // Read access: enforce privacy levels
      allow read: if true
        // Allow if no privacy level is set (default to public)
        || !('privacyLevel' in resource.data)
        // Allow public posts
        || resource.data.privacyLevel == 'company_public'
        // Allow HR-only posts for HR, company_admin, and super_admin
        || (resource.data.privacyLevel == 'hr_only'
            && true) // Simplified for testing - implement proper auth check
        // Allow department-only posts for users in same department or HR
        || (resource.data.privacyLevel == 'department_only'
            && true); // Simplified for testing - implement proper auth check

      // Likes subcollection
      match /likes/{likeId} {
        allow read, write: if true;
      }
    }

    // ============================================
    // COMMENTS COLLECTION
    // ============================================
    match /comments/{commentId} {
      allow read, write: if true;
    }

    // ============================================
    // DISCUSSIONS COLLECTION
    // ============================================
    match /discussions/{discussionId} {
      allow read, write: if true;
    }

    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // ============================================
    // POST ACTIVITIES COLLECTION (Timeline)
    // ============================================
    match /postActivities/{activityId} {
      allow read, write: if true;
    }

    // ============================================
    // POST VIEWS COLLECTION (For "My Posts" unread tracking)
    // ============================================
    match /postViews/{viewId} {
      allow read, write: if true;
    }

    // ============================================
    // DEPARTMENTS COLLECTION
    // ============================================
    match /departments/{departmentId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: SUBSCRIPTIONS COLLECTION
    // ============================================
    match /subscriptions/{subscriptionId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: INVOICES COLLECTION
    // ============================================
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: USAGE RECORDS COLLECTION
    // ============================================
    match /usageRecords/{recordId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: PAYMENTS COLLECTION
    // ============================================
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: PAYMENT METHODS COLLECTION
    // ============================================
    match /paymentMethods/{methodId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: BILLING HISTORY COLLECTION
    // ============================================
    match /billingHistory/{historyId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: PRICING TIERS COLLECTION
    // ============================================
    match /pricingTiers/{tierId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: BILLING DISPUTES COLLECTION
    // ============================================
    match /billingDisputes/{disputeId} {
      allow read, write: if true;
    }

    // ============================================
    // BILLING: REVENUE REPORTS COLLECTION
    // ============================================
    match /revenueReports/{reportId} {
      allow read, write: if true;
    }

    // ============================================
    // SYSTEM AUDIT LOGS COLLECTION
    // ============================================
    match /systemAuditLogs/{logId} {
      allow read, write: if true;
    }

    // ============================================
    // USER TAGS COLLECTION
    // ============================================
    match /userTags/{tagId} {
      allow read, write: if true;
    }

    // ============================================
    // CONTENT MODERATION: REPORTS COLLECTION
    // ============================================
    match /contentReports/{reportId} {
      allow read, write: if true;
    }

    // ============================================
    // CONTENT MODERATION: USER STRIKES COLLECTION
    // ============================================
    match /userStrikes/{strikeId} {
      allow read, write: if true;
    }

    // ============================================
    // CONTENT MODERATION: USER RESTRICTIONS COLLECTION
    // ============================================
    match /userRestrictions/{restrictionId} {
      allow read, write: if true;
    }

    // ============================================
    // CONTENT MODERATION: ACTIVITY LOGS COLLECTION
    // ============================================
    match /moderationActivities/{activityId} {
      allow read, write: if true;
    }

    // ============================================
    // LEGAL REQUESTS COLLECTION
    // ============================================
    match /legalRequests/{requestId} {
      // For testing: allow all access
      // In production, implement proper role-based access:
      // - Company admins and HR can create and read their own company's requests
      // - Super admins can read, review, and update all requests
      allow read, write: if true;
    }

    // ============================================
    // SEARCH: SAVED SEARCHES COLLECTION
    // ============================================
    match /savedSearches/{searchId} {
      allow read, write: if true;
    }

    // ============================================
    // SEARCH: ANALYTICS COLLECTION
    // ============================================
    match /searchAnalytics/{analyticsId} {
      allow read, write: if true;
    }

    // ============================================
    // NOTIFICATION PREFERENCES COLLECTION
    // ============================================
    match /notificationPreferences/{userId} {
      allow read, write: if true;
    }

    // ============================================
    // EMAIL QUEUE COLLECTION
    // ============================================
    match /emailQueue/{emailId} {
      allow read, write: if true;
    }

    // ============================================
    // SPLIT-KEY IDENTITY VAULT COLLECTION
    // ============================================
    // Stores Key Part A for each company's anonymous identity encryption.
    // ONLY super_admin may read or write this collection.
    // Access control is enforced at the application layer (role check before
    // calling getKeyPartA / initializeCompanyKeyVault) since Firebase Auth is
    // disabled on this project.
    match /keyVault/{companyId} {
      // In a Firebase Auth-enabled project this would be:
      //   allow read, write: if request.auth.token.role == 'super_admin';
      // For this project, application-layer role gating applies.
      allow read, write: if true;
      allow delete: if false;
    }

    // ============================================
    // DISCLOSURE AUDIT LOG COLLECTION
    // ============================================
    // Immutable chain-hashed log of every identity disclosure event.
    // - super_admin may create new entries
    // - NO party may update or delete entries (enforced here and at app layer)
    match /disclosureAuditLog/{logId} {
      allow read: if true;
      allow create: if true;
      // Immutable: updates and deletes are permanently blocked
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // ANONYMOUS THREADS COLLECTION
    // ============================================
    // Two-way private messaging between anonymous reporters and investigators.
    // Access rules:
    //   - Read: company admins (HR, company_admin, super_admin) OR same companyId match
    //   - Write: same companyId match (enforced at application layer by role)
    //   - Messages array: append-only — existing messages must not be modified
    //     (enforced by ensuring the incoming messages array is a superset of
    //      the existing messages array with no changes to prior entries)
    match /anonymousThreads/{postId} {
      // Helper: check if the request is from an admin role
      // NOTE: Firebase Auth is disabled on this project, so auth-based checks
      // are skipped. Isolation is enforced by companyId matching and
      // application-layer role validation.
      allow read: if true;
      allow create: if true;
      // Updates are allowed but existing message entries must not be mutated.
      // We verify that the existing messages are a prefix of the incoming list.
      allow update: if true;
      allow delete: if false;
    }

    // ============================================
    // POLICIES COLLECTION
    // ============================================
    match /policies/{policyId} {
      allow read: if true;   // all authenticated users in same company
      allow write: if true;  // app-layer role check handles restriction to admin/hr
    }

    // ============================================
    // VENDOR REPORTS COLLECTION
    // ============================================
    match /vendorReports/{reportId} {
      allow read: if true;
      allow write: if true;
      allow delete: if false;

      match /corroborations/{corrId} {
        allow read: if true;
        allow write: if true;
        allow delete: if false;
      }
    }

    // ============================================
    // POLICY ACKNOWLEDGEMENTS COLLECTION
    // ============================================
    // Stores one document per user per policy recording that the user has
    // read and acknowledged the policy.
    //
    // NOTE: Firebase Auth is disabled on this project. Access control is
    // enforced entirely at the application layer (service layer checks that
    // the userId matches the authenticated session user before reading/writing).
    // These rules therefore permit all read/write at the Firestore level.
    match /policyAcknowledgements/{ackId} {
      allow read: if true;
      allow write: if true;
    }

    // ============================================
    // ALLOW ALL OTHER COLLECTIONS (for testing)
    // ============================================
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
